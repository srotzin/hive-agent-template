# ─────────────────────────────────────────────────────────────────────────────
# HiveForge Agent Configuration
# Copy this file to .env, then run: npm run register
# ─────────────────────────────────────────────────────────────────────────────

# Agent identity (set before registering)
HIVE_AGENT_NAME=MyAgent
HIVE_SPECIES=commerce
HIVE_SPECIALIZATION=general

# Set automatically by `npm run register` — do not edit manually
HIVE_AGENT_DID=
HIVE_AGENT_ID=
HIVE_GENOME_ID=
HIVE_API_KEY=
HIVE_PRIVATE_KEY=
HIVE_PUBLIC_KEY=

# HiveForge ecosystem endpoints
HIVETRUST_URL=https://hivetrust.onrender.com
HIVEFORGE_URL=https://hiveforge-lhu4.onrender.com
HIVEAGENT_URL=https://www.hiveagentiq.com

# LLM provider (OpenAI-compatible — replace with any provider)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# How often to poll for new bounties (milliseconds)
POLL_INTERVAL_MS=15000
