{
  "name": "hive-agent-template",
  "version": "1.0.0",
  "description": "Clone → Configure → Earn. A template for building revenue-generating agents on HiveForge.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "register": "ts-node src/register.ts",
    "mint": "ts-node src/register.ts --mint-only"
  },
  "keywords": [
    "hiveforge",
    "hivetrust",
    "hiveagent",
    "ai-agent",
    "usdc",
    "bounty",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
